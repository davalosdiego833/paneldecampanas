{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node",
        "noEmit": false,
        "outDir": "dist/server",
        "rootDir": "server",
        "target": "ES2020",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true
    },
    "include": [
        "server/**/*"
    ]
}